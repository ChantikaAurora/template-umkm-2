generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("VISITOR")
  status    String   @default("ACTIVE")
  avatar    String?
  regionId  String?
  region    Region?  @relation(fields: [regionId], references: [id])
  umkmId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  umkms     Umkm[]   @relation("UmkmOwner")
  stories   Story[]
  events    Event[]  @relation("EventCreator")
  notifications Notification[]
  activityLogs  ActivityLog[]
}

model Region {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  users     User[]
  umkms     Umkm[]
}

model Umkm {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  address     String?
  phone       String?
  whatsapp    String?
  website     String?
  category    String?
  logo        String?
  banner      String?
  status      String   @default("PENDING")
  regionId    String
  region      Region   @relation(fields: [regionId], references: [id])
  ownerId     String
  owner       User     @relation("UmkmOwner", fields: [ownerId], references: [id])
  products    Product[]
  promos      Promo[]
  stories     Story[]
  waOrders    WhatsAppOrderLog[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  icon     String?
  products Product[]
}

model Product {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  price       Float?
  status      String         @default("PENDING")
  umkmId      String
  umkm        Umkm           @relation(fields: [umkmId], references: [id])
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  waOrders    WhatsAppOrderLog[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order     Int     @default(0)
}

model Promo {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String?
  link        String?
  status      String   @default("PENDING")
  umkmId      String?
  umkm        Umkm?    @relation(fields: [umkmId], references: [id])
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
}

model Story {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  tags        String?
  status      String   @default("PENDING")
  publishedAt DateTime?
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  umkmId      String?
  umkm        Umkm?    @relation(fields: [umkmId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id           String   @id @default(cuid())
  title        String
  description  String?
  image        String?
  location     String?
  isOnline     Boolean  @default(false)
  meetLink     String?
  startDate    DateTime
  endDate      DateTime?
  maxAttendee  Int?
  status       String   @default("PENDING")
  createdBy    String
  creator      User     @relation("EventCreator", fields: [createdBy], references: [id])
  registrations EventRegistration[]
  createdAt    DateTime @default(now())
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id])
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())
}

model WhatsAppOrderLog {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  umkmId    String
  umkm      Umkm     @relation(fields: [umkmId], references: [id])
  buyerName String?
  buyerPhone String?
  message   String?
  createdAt DateTime @default(now())
}

model HomepageSection {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String?
  subtitle  String?
  content   String?
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model App {
  id          String   @id @default(cuid())
  name        String
  description String?
  logo        String?
  callbackUrl String?
  clientKey   String   @default(cuid())
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String?
  entityId  String?
  createdAt DateTime @default(now())
}
